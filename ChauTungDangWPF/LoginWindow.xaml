<Window x:Class="ChauTungDangWPF.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ChauTungDangWPF"
        mc:Ignorable="d"
        Title="LoginWindow"
        Height="520"
        Width="920"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="Transparent"
        AllowsTransparency="True">
    <Window.Resources>
        <LinearGradientBrush x:Key="PrimaryBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#0099FF" Offset="0" />
            <GradientStop Color="#28AEED" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="AccentBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#DA34AE" Offset="0" />
            <GradientStop Color="#596FDD" Offset="1" />
        </LinearGradientBrush>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="36" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="#7D7D7D" />
            <Setter Property="BorderThickness" Value="0,0,0,2" />
            <Setter Property="CaretBrush" Value="LightGray" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontFamily" Value="Montserrat" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Height" Value="36" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="#7D7D7D" />
            <Setter Property="BorderThickness" Value="0,0,0,2" />
            <Setter Property="CaretBrush" Value="LightGray" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontFamily" Value="Montserrat" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style x:Key="RoundedActionButton" TargetType="Button">
            <Setter Property="Height" Value="42" />
            <Setter Property="Width" Value="150" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontFamily" Value="Montserrat" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="RootBorder"
                                CornerRadius="21"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder" Property="Opacity" Value="0.9" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="RootBorder" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.98" ScaleY="0.98" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Border CornerRadius="16"
                BorderThickness="2"
                Opacity="0.98"
                SnapsToDevicePixels="True">
            <Border.Effect>
                <DropShadowEffect Color="#000000"
                                  BlurRadius="24"
                                  ShadowDepth="8"
                                  Opacity="0.45" />
            </Border.Effect>
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#0099FF" Offset="0" />
                    <GradientStop Color="#596FDD" Offset="0.30" />
                    <GradientStop Color="#8C57CA" Offset="0.48" />
                    <GradientStop Color="#DA34AE" Offset="0.75" />
                    <GradientStop Color="#FF60B1E7" Offset="1" />
                </LinearGradientBrush>
            </Border.BorderBrush>
            <Border.Background>
                <LinearGradientBrush StartPoint="0,1" EndPoint="1,0">
                    <GradientStop Color="#070725" Offset="0" />
                    <GradientStop Color="#211A63" Offset="0.55" />
                    <GradientStop Color="#4A2BD8" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.15*" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Border Background="#140F3A" Opacity="0.38" />
                    <StackPanel Margin="46" VerticalAlignment="Center">
                        <TextBlock Text="FUMini Hotel Management"
                                   Foreground="White"
                                   FontFamily="Montserrat"
                                   FontSize="28"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,16" />
                        <TextBlock Text="Secure access to room, customer, order and report management."
                                   Foreground="#D4D4D4"
                                   FontFamily="Montserrat"
                                   FontSize="13"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,24" />

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <Border Width="12" Height="12" CornerRadius="6" Background="#0099FF" Margin="0,0,10,0" />
                            <TextBlock Text="Admin dashboard with full management tools"
                                       Foreground="White"
                                       FontFamily="Montserrat"
                                       FontSize="12" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <Border Width="12" Height="12" CornerRadius="6" Background="#DA34AE" Margin="0,0,10,0" />
                            <TextBlock Text="Customer dashboard with restricted permissions"
                                       Foreground="White"
                                       FontFamily="Montserrat"
                                       FontSize="12" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Border Width="12" Height="12" CornerRadius="6" Background="#28AEED" Margin="0,0,10,0" />
                            <TextBlock Text="Modern UI with transparent window and gradient styling"
                                       Foreground="White"
                                       FontFamily="Montserrat"
                                       FontSize="12" />
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <Grid Grid.Column="1">
                    <Button x:Name="btnClose"
                            Width="32"
                            Height="32"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="0,16,16,0"
                            Content="✕"
                            FontFamily="Segoe UI"
                            FontSize="14"
                            FontWeight="Bold"
                            Foreground="White"
                            Background="#22FFFFFF"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="btnCancel_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border CornerRadius="16" Background="{TemplateBinding Background}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Border Width="390"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            CornerRadius="14"
                            Background="#140F3A"
                            Padding="30">
                        <Border.Effect>
                            <DropShadowEffect Color="#000000"
                                              BlurRadius="16"
                                              ShadowDepth="6"
                                              Opacity="0.25" />
                        </Border.Effect>

                        <StackPanel>
                            <TextBlock Text="LOGIN WINDOW"
                                       Foreground="White"
                                       FontSize="30"
                                       FontWeight="SemiBold"
                                       FontFamily="Montserrat"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,4" />

                            <TextBlock Text="Enter your credentials to continue"
                                       Foreground="#D0D0D0"
                                       FontSize="12"
                                       FontFamily="Montserrat"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,26" />

                            <TextBlock Text="Email / Username"
                                       Foreground="DarkGray"
                                       FontSize="12"
                                       FontFamily="Montserrat"
                                       Margin="0,0,0,6" />
                            <TextBox x:Name="txtUser"
                                     Margin="0,0,0,18" 
                                     Text="admin@FUMiniHotelSystem.com"/>

                            <TextBlock Text="Password"
                                       Foreground="DarkGray"
                                       FontSize="12"
                                       FontFamily="Montserrat"
                                       Margin="0,0,0,6" />
                            <PasswordBox x:Name="txtPass"
                                         Margin="0,0,0,28" 
                                         Password="@@abc123@@"/>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button x:Name="btnLogin"
                                        Content="LOG IN"
                                        Margin="0,0,12,0"
                                        Background="{StaticResource PrimaryBrush}"
                                        Style="{StaticResource RoundedActionButton}"
                                        Click="btnLogin_Click" />

                                <Button x:Name="btnCancel"
                                        Content="CANCEL"
                                        Background="{StaticResource AccentBrush}"
                                        Style="{StaticResource RoundedActionButton}"
                                        Click="btnCancel_Click" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
