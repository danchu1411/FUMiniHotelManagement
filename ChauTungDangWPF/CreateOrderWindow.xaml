<Window x:Class="ChauTungDangWPF.CreateOrderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create Booking Order" 
        Height="650" 
        Width="650"
        WindowStartupLocation="CenterOwner"
        Background="#F3F6FB"
        ResizeMode="NoResize"
        FontFamily="Segoe UI">

    <Window.Resources>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#344054" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="ComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#D0D8FF" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,0,0,20" />
        </Style>

        <Style x:Key="DatePickerStyle" TargetType="DatePicker">
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="5" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,0,0,20" />
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="40,35,40,35">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" 
                       Text="Create New Order" 
                       FontSize="32" 
                       FontWeight="Bold" 
                       Foreground="#0B1030" 
                       Margin="0,0,0,35" />

            <TextBlock Grid.Row="1" Text="Select Customer *" Style="{StaticResource LabelStyle}" />
            <ComboBox x:Name="cboCustomer" Grid.Row="2" Style="{StaticResource ComboBoxStyle}" />

            <TextBlock Grid.Row="3" Text="Select Room *" Style="{StaticResource LabelStyle}" />
            <ComboBox x:Name="cboRoom" Grid.Row="4" Style="{StaticResource ComboBoxStyle}" />

            <TextBlock Grid.Row="5" Text="Start Date (Check-in) *" Style="{StaticResource LabelStyle}" />
            <DatePicker x:Name="dpStartDate" Grid.Row="6" Style="{StaticResource DatePickerStyle}" />

            <TextBlock Grid.Row="7" Text="End Date (Check-out) *" Style="{StaticResource LabelStyle}" />
            <DatePicker x:Name="dpEndDate" Grid.Row="8" Style="{StaticResource DatePickerStyle}" />

            <StackPanel Grid.Row="9" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button x:Name="btnSave" Content="Save Order" Width="130" Height="48" Background="#0099FF" Foreground="White" FontWeight="SemiBold" FontSize="14" BorderThickness="0" Margin="0,0,15,0" Click="btnSave_Click" Cursor="Hand" />
                <Button x:Name="btnCancel" Content="Cancel" Width="130" Height="48" Background="#E4E7EC" Foreground="#344054" FontWeight="SemiBold" FontSize="14" BorderThickness="0" Click="btnCancel_Click" Cursor="Hand" />
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Window>