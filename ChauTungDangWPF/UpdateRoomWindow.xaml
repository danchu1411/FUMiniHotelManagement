<Window x:Class="ChauTungDangWPF.UpdateRoomWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Update Room" 
        Height="650" 
        Width="650"
        WindowStartupLocation="CenterOwner"
        Background="#F3F6FB"
        ResizeMode="NoResize"
        FontFamily="Segoe UI">

    <Window.Resources>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#344054" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#D0D8FF" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,0,0,20" />
        </Style>

        <Style x:Key="ComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#D0D8FF" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,0,0,20" />
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="40,35,40,35">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="Update Room"
                       FontSize="32"
                       FontWeight="Bold"
                       Foreground="#0B1030"
                       Margin="0,0,0,35" />

            <TextBlock Grid.Row="1" Text="Room Number *" Style="{StaticResource LabelStyle}" />
            <TextBox x:Name="txtRoomNumber" Grid.Row="2" Style="{StaticResource InputStyle}" />

            <TextBlock Grid.Row="3" Text="Room Type *" Style="{StaticResource LabelStyle}" />
            <ComboBox x:Name="cboRoomType" Grid.Row="4" Style="{StaticResource ComboBoxStyle}" />

            <TextBlock Grid.Row="5" Text="Description" Style="{StaticResource LabelStyle}" />
            <TextBox x:Name="txtDescription" Grid.Row="6" Height="120" Padding="14,10" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" BorderThickness="1" BorderBrush="#D0D8FF" FontSize="12" Margin="0,0,0,20" />

            <TextBlock Grid.Row="7" Text="Max Capacity (People) *" Style="{StaticResource LabelStyle}" />
            <TextBox x:Name="txtCapacity" Grid.Row="8" Style="{StaticResource InputStyle}" />

            <TextBlock Grid.Row="9" Text="Price Per Day ($) *" Style="{StaticResource LabelStyle}" />
            <TextBox x:Name="txtPrice" Grid.Row="10" Style="{StaticResource InputStyle}" />

            <StackPanel Grid.Row="12" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button x:Name="btnSave" Content="Save" Width="130" Height="48" Background="#0099FF" Foreground="White" FontWeight="SemiBold" FontSize="14" BorderThickness="0" Margin="0,0,15,0" Click="btnSave_Click" Cursor="Hand" />
                <Button x:Name="btnCancel" Content="Cancel" Width="130" Height="48" Background="#E4E7EC" Foreground="#344054" FontWeight="SemiBold" FontSize="14" BorderThickness="0" Click="btnCancel_Click" Cursor="Hand" />
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Window>
