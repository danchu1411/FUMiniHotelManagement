<Window x:Class="ChauTungDangWPF.UpdateCustomerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="Update Customer" 
        Height="650" 
        Width="650"
        WindowStartupLocation="CenterOwner"
        Background="#F3F6FB"
        ResizeMode="NoResize"
        FontFamily="Segoe UI">
    
    <Window.Resources>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#344054" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#D0D8FF" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,0,0,20" />
        </Style>

        <Style x:Key="PasswordStyle" TargetType="PasswordBox">
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#D0D8FF" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,0,0,20" />
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="40,35,40,35">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Title -->
            <TextBlock Grid.Row="0" 
                       Text="Update Customer" 
                       FontSize="32" 
                       FontWeight="Bold" 
                       Foreground="#0B1030" 
                       Margin="0,0,0,35" />

            <!-- Full Name -->
            <TextBlock Grid.Row="1" Text="Full Name *" Style="{StaticResource LabelStyle}" />
            <TextBox x:Name="txtFullName" Grid.Row="2" Style="{StaticResource InputStyle}" />

            <!-- Email -->
            <TextBlock Grid.Row="3" Text="Email Address *" Style="{StaticResource LabelStyle}" />
            <TextBox x:Name="txtEmail" Grid.Row="4" Style="{StaticResource InputStyle}" />

            <!-- Phone -->
            <TextBlock Grid.Row="5" Text="Phone Number *" Style="{StaticResource LabelStyle}" />
            <TextBox x:Name="txtPhone" Grid.Row="6" Style="{StaticResource InputStyle}" MaxLength="12" />

            <!-- Birthday -->
            <TextBlock Grid.Row="7" Text="Birthday" Style="{StaticResource LabelStyle}" />
            <DatePicker x:Name="dpBirthday"
                        Grid.Row="8"
                        Height="42"
                        Padding="14,10"
                        BorderThickness="1"
                        BorderBrush="#D0D8FF"
                        FontSize="12"
                        Margin="0,0,0,20"
                        DisplayDateEnd="{x:Static sys:DateTime.Today}"
                        SelectedDateFormat="Short" />

            <!-- Password -->
            <TextBlock Grid.Row="9" Text="Password *" Style="{StaticResource LabelStyle}" />
            <PasswordBox x:Name="pwdPassword" Grid.Row="10" Style="{StaticResource PasswordStyle}" />

            <!-- Buttons -->
            <StackPanel Grid.Row="11" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button x:Name="btnSave" Content="Save" Width="130" Height="48" Background="#0099FF" Foreground="White" FontWeight="SemiBold" FontSize="14" BorderThickness="0" Margin="0,0,15,0" Click="btnSave_Click" Cursor="Hand" />
                <Button x:Name="btnCancel" Content="Cancel" Width="130" Height="48" Background="#E4E7EC" Foreground="#344054" FontWeight="SemiBold" FontSize="14" BorderThickness="0" Click="btnCancel_Click" Cursor="Hand" />
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Window>
