<Window x:Class="ChauTungDangWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ChauTungDangWPF"
        mc:Ignorable="d"
        Title="Hotel Management"
        Height="780"
        Width="1280"
        WindowStartupLocation="CenterScreen"
        Background="#F3F6FB">
    <Window.Resources>
        <SolidColorBrush x:Key="SidebarBase" Color="#0E1330" />
        <SolidColorBrush x:Key="SidebarAccent" Color="#472FDE" />
        <SolidColorBrush x:Key="ContentBase" Color="White" />
        <SolidColorBrush x:Key="PrimaryAction" Color="#0099FF" />
        <SolidColorBrush x:Key="SuccessAction" Color="#1B7140" />
        <SolidColorBrush x:Key="WarningAction" Color="#A2AA3D" />
        <SolidColorBrush x:Key="DangerAction" Color="#EF8F18" />

        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="44" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#1C244D" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="RootBorder" CornerRadius="10" Background="{TemplateBinding Background}">
                            <ContentPresenter Margin="16,0" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="#263165" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40" />
            <Setter Property="MinWidth" Value="110" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="8" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Padding="24">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#0B1030" Offset="0" />
                    <GradientStop Color="#141B45" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,8,0,28">
                    <TextBlock Text="Hotel Management"
                               Foreground="White"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6" />
                    <TextBlock Text="Dashboard"
                               Foreground="#C7C9E2"
                               FontSize="12" />
                </StackPanel>

                <StackPanel Grid.Row="1">
                    <TextBlock Text="Modules"
                               Foreground="#8F96C9"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Margin="0,0,0,12" />

                    <Button Content="Room / RoomType" Tag="Room" Click="NavButton_Click" Style="{StaticResource NavButtonStyle}" />
                    <Button Content="Customer" Tag="Customer" Click="NavButton_Click" Style="{StaticResource NavButtonStyle}" />
                    <Button Content="Order" Tag="Order" Click="NavButton_Click" Style="{StaticResource NavButtonStyle}" />
                    <Button Content="Status Report" x:Name="btnReport" Tag="Report" Click="NavButton_Click" Style="{StaticResource NavButtonStyle}" />
                </StackPanel>

                <StackPanel Grid.Row="2">
                    <Border Height="1" Background="#303A72" Margin="0,0,0,16" />
                    <TextBlock Text="Current User"
                               Foreground="#8F96C9"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6" />
                    <TextBlock Text="Admin"
                               x:Name="txtCurrentUser"
                               Foreground="White"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Margin="0,0,0,16" />

                    <Button x:Name="btnLogout"
                            Content="Logout"
                            Background="#2C3A78"
                            Style="{StaticResource ActionButtonStyle}"
                            Click="btnLogout_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Background="{StaticResource ContentBase}" CornerRadius="16" Padding="22" Margin="0,0,0,18">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" BlurRadius="18" ShadowDepth="4" Opacity="0.12" />
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock 
                                   x:Name="txtModuleTitle"
                                   Text="Main Dashboard"
                                   Foreground="#16213E"
                                   FontSize="28"
                                   FontWeight="SemiBold" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock Text="Status: Ready"
                                   Foreground="#667085"
                                   FontSize="12"
                                   HorizontalAlignment="Right" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border x:Name="borderSearch"  Grid.Row="1" Background="{StaticResource ContentBase}" CornerRadius="16" Padding="18" Margin="0,0,0,18">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*" />
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Grid x:Name="gridNormalSearch" Grid.Column="0" Grid.ColumnSpan="2" Visibility="Visible">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Search" Foreground="#344054" FontWeight="SemiBold" Margin="0,0,0,8" />
                            <TextBox x:Name="txtSearch" Height="40" Padding="12,0" Text="Search keyword or date..." Foreground="#98A2B3" TextChanged="txtSearch_TextChanged" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                            <TextBlock Text="Filter" Foreground="#344054" FontWeight="SemiBold" Margin="0,0,0,8" />
                            <ComboBox x:Name="cboFilter" Height="40" Padding="10,0" SelectionChanged="cboFilter_SelectionChanged">
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <Grid x:Name="gridReportSearch" Grid.Column="0" Grid.ColumnSpan="2" Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Start Date *" Foreground="#344054" FontWeight="SemiBold" Margin="0,0,0,8" />
                            <DatePicker x:Name="dpReportStart" Height="40" Padding="5" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                            <TextBlock Text="End Date *" Foreground="#344054" FontWeight="SemiBold" Margin="0,0,0,8" />
                            <DatePicker x:Name="dpReportEnd" Height="40" Padding="5" />
                        </StackPanel>
                    </Grid>

                    <Button Grid.Column="2" Content="Find" Width="110" Margin="12,24,0,0" Background="{StaticResource PrimaryAction}" Style="{StaticResource ActionButtonStyle}" Click="btnFind_Click" />
                </Grid>
            </Border>

            <Border Grid.Row="2" Background="{StaticResource ContentBase}" CornerRadius="16" Padding="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <WrapPanel Margin="0,0,0,14">
                        <Button x:Name="btnCreateRoom" Content="Create Room" Background="{StaticResource PrimaryAction}" Style="{StaticResource ActionButtonStyle}" Click="btnCreateRoom_Click" />
                        <Button x:Name="btnCreateRoomType" Content="Create Room Type" Background="{StaticResource PrimaryAction}" Style="{StaticResource ActionButtonStyle}" Click="btnCreateRoomType_Click" />
                        <Button x:Name="btnCreateCustomer" Content="Create Customer" Background="{StaticResource PrimaryAction}" Style="{StaticResource ActionButtonStyle}" Click="btnCreateCustomer_Click" />
                        <Button x:Name="btnCreateOrder" Content="Create Order" Background="{StaticResource PrimaryAction}" Style="{StaticResource ActionButtonStyle}" Click="btnCreateOrder_Click" />
                        <Button x:Name="btnOrderDetails" Content="Details" Background="#6B7280" Style="{StaticResource ActionButtonStyle}" Click="btnOrderDetails_Click" />
                        <Button x:Name="btnCheckInOrder" Content="Check-in" Background="{StaticResource SuccessAction}" Style="{StaticResource ActionButtonStyle}" Click="btnCheckInOrder_Click" />
                        <Button x:Name="btnCheckOutOrder" Content="Check-out" Background="#A855F7" Style="{StaticResource ActionButtonStyle}" Click="btnCheckOutOrder_Click" />
                        <Button x:Name="btnCancelOrder" Content="Cancel Order" Background="{StaticResource WarningAction}" Style="{StaticResource ActionButtonStyle}" Click="btnCancelOrder_Click" />
                        <Button x:Name="btnUpdate" Content="Update" Background="{StaticResource SuccessAction}" Style="{StaticResource ActionButtonStyle}" Click="btnUpdate_Click" />
                        <Button x:Name="btnDelete" Content="Delete" Background="{StaticResource WarningAction}" Style="{StaticResource ActionButtonStyle}" Click="btnDelete_Click" />
                    </WrapPanel>

                    <UniformGrid x:Name="gridReportStats" Grid.Row="1" Columns="3" Margin="0,0,0,16" Visibility="Collapsed">
                        <Border Background="#F0F5FF" CornerRadius="8" Padding="12" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="Tổng doanh thu thực tế" FontSize="12" Foreground="#667085" FontWeight="SemiBold"/>
                                <TextBlock x:Name="txtTotalRevenue" Text="$0.00" FontSize="20" FontWeight="Bold" Foreground="#0099FF" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#EFFDF5" CornerRadius="8" Padding="12" Margin="4,0,4,0">
                            <StackPanel>
                                <TextBlock Text="Loại phòng thuê nhiều nhất" FontSize="12" Foreground="#667085" FontWeight="SemiBold"/>
                                <TextBlock x:Name="txtMostBookedRoomType" Text="N/A" FontSize="15" FontWeight="Bold" Foreground="#1B7140" Margin="0,4,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#FFF9F0" CornerRadius="8" Padding="12" Margin="8,0,0,0">
                            <StackPanel>
                                <TextBlock Text="Khách đặt phòng nhiều nhất" FontSize="12" Foreground="#667085" FontWeight="SemiBold"/>
                                <TextBlock x:Name="txtTopCustomer" Text="N/A" FontSize="15" FontWeight="Bold" Foreground="#EF8F18" Margin="0,4,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <DataGrid Grid.Row="2"
                        x:Name="dgData"
                        AutoGenerateColumns="False"
                        CanUserAddRows="False"
                        HeadersVisibility="Column"
                        GridLinesVisibility="Horizontal"
                        SelectionMode="Single"
                        Margin="0,0,0,12">
                    </DataGrid>
                    
                    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button x:Name="btnPrev" Content="◀ Prev" Width="60" Height="32" Margin="4,0" Background="#E4E7EC" Foreground="#344054" BorderThickness="0" Click="btnPrev_Click" />
                        <StackPanel x:Name="paginationPanel" Orientation="Horizontal" Margin="10,0" VerticalAlignment="Center" />
                        <Button x:Name="btnNext" Content="Next ▶" Width="60" Height="32" Margin="4,0" Background="#E4E7EC" Foreground="#344054" BorderThickness="0" Click="btnNext_Click" />
                        <TextBlock x:Name="txtPageInfo" Text="Page 1 of 1" Margin="20,0,0,0" VerticalAlignment="Center" Foreground="#344054" FontSize="12" FontWeight="SemiBold" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
